{
    "name": "lll-lll-lll-lll/depone",
    "description": "A static analysis tool for PHP that helps you eliminate require_once-related issues.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "symfony/console": "^8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^13.2",
        "phpstan/phpstan": "^2.1",
        "friendsofphp/php-cs-fixer": "^3.66"
    },
    "autoload": {
        "psr-4": {
            "Depone\\Internal\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Depone\\Tests\\": "tests/"
        }
    },
    "bin": [
        "bin/depone"
    ],
    "scripts": {
        "test": "vendor/bin/phpunit -c phpunit.xml.dist",
        "analyse": "vendor/bin/phpstan analyse",
        "cs": "vendor/bin/php-cs-fixer fix --dry-run --diff --verbose --sequential",
        "cs-fix": "vendor/bin/php-cs-fixer fix --verbose --sequential",
        "check": [
            "@cs",
            "@analyse",
            "@test"
        ]
    }
}
